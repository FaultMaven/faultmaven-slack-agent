{
  "display_information": {
    "name": "FaultMaven",
    "description": "AI troubleshooting copilot — finds a problem's root cause from your logs, errors, and configs. Methodical and evidence-based.",
    "background_color": "#1a1a2e"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "FaultMaven",
      "always_online": true
    },
    "assistant_view": {
      "assistant_description": "Hand me a log, an error, or a config and I'll help you find the root cause — methodical, evidence-based, grounded in your runbooks.",
      "suggested_prompts": []
    },
    "shortcuts": [
      {
        "name": "Ask",
        "type": "message",
        "callback_id": "fm_investigate_message",
        "description": "Open a FaultMaven investigation seeded with this message"
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "assistant:write",
        "chat:write",
        "commands",
        "reactions:write",
        "app_mentions:read",
        "files:read",
        "im:history",
        "channels:history",
        "groups:history"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "assistant_thread_started",
        "message.im",
        "message.channels",
        "message.groups",
        "app_mention"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": true,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
