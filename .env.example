# FaultMaven Slack Agent — environment template
# Copy to `.env` and fill in. Never commit the populated file.

# --- Transport ---
# "socket" = local dev against a single dev app (Socket Mode; no public URL).
# "http"   = hosted HTTP/Events + multi-workspace OAuth (the production transport;
#            see docs/HOSTING.md). Each transport needs a different credential set
#            below; the agent fails fast at boot if any are missing.
SLACK_TRANSPORT=socket

# --- Slack: Socket Mode (SLACK_TRANSPORT=socket) ---
# Create a SEPARATE dev app from `manifest.dev.json` (Socket Mode enabled) — the
# hosted `manifest.json` has Socket Mode OFF. See docs/LIVE_TEST.md.
# Bot User OAuth token from "OAuth & Permissions".
SLACK_BOT_TOKEN=xoxb-your-bot-token
# App-level token ("xapp-...") with connections:write — required for Socket Mode.
SLACK_APP_TOKEN=xapp-your-app-token

# --- Slack: HTTP/OAuth (SLACK_TRANSPORT=http) ---
# From "Basic Information → App Credentials".
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Signing secret verifies inbound HTTP requests (required in http mode; also
# used by Socket Mode if set).
SLACK_SIGNING_SECRET=
# SQLAlchemy URL backing the per-team InstallationStore + OAuth state store.
# Empty → a repo-anchored SQLite file (dev). Postgres in the cluster, e.g.
#   postgresql://faultmaven_slack:PASSWORD@postgres:5432/faultmaven_slack
SLACK_DATABASE_URL=
# Optional: pin the OAuth redirect (else derived from the request host).
SLACK_OAUTH_REDIRECT_URI=
# Port the HTTP server binds inside the container.
HTTP_PORT=3000

# --- FaultMaven core API ---
FAULTMAVEN_API_URL=http://localhost:8090
# Pre-obtained bearer token. Leave empty to bootstrap one via /auth/dev-login
# (local AUTH_MODE only) using the username below.
FAULTMAVEN_API_TOKEN=
FAULTMAVEN_DEV_LOGIN_USERNAME=admin
FAULTMAVEN_REQUEST_TIMEOUT=120

# --- Local state ---
CASE_STORE_PATH=data/cases.db
LOG_LEVEL=INFO

# --- Manifest management (OPS-ONLY — not needed to run the agent) ---
# Used only by scripts/push_manifest.py, to apply manifest.json edits via the
# Slack API instead of hand-pasting into the App Manifest tab. These are NOT the
# tokens above and are read only by that script:
#   SLACK_CONFIG_TOKEN — an app *configuration* token ("xoxe.xoxp-..."), a
#     different kind from SLACK_BOT_TOKEN/SLACK_APP_TOKEN. Generate it at the TOP
#     of https://api.slack.com/apps under "Your app configuration tokens" (not in
#     the app's settings); it is workspace-scoped and expires ~12h.
#   SLACK_APP_ID — the app's ID ("A0..."), from Basic Information → App Credentials.
# SLACK_CONFIG_TOKEN=xoxe.xoxp-...
# SLACK_APP_ID=A0XXXXXXX
