# FaultMaven Slack Agent — environment template
# Copy to `.env` and fill in. Never commit the populated file.

# --- Slack (required) ---
# Bot User OAuth token from your app's "OAuth & Permissions" page.
SLACK_BOT_TOKEN=xoxb-your-bot-token
# Signing secret from your app's "Basic Information" page.
SLACK_SIGNING_SECRET=your-signing-secret

# --- FaultMaven core API ---
# Leave FAULTMAVEN_API_KEY empty to run in mock mode (no live backend needed).
FAULTMAVEN_API_URL=http://localhost:8090
FAULTMAVEN_API_KEY=
FAULTMAVEN_REQUEST_TIMEOUT=60

# --- Server ---
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=INFO

# --- Replay protection ---
SLACK_REQUEST_MAX_AGE=300
